  panNumber           String?      @db.VarChar(10)
  billingAddress      Json?
  shippingAddress     Json?
  creditLimit         Decimal?     @db.Decimal(12, 2)
  paymentTermsDays    Int          @default(0)
  outstandingBalance  Decimal      @default(0) @db.Decimal(12, 2)
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  invoices Invoice[]

  @@index([gstin])
  @@index([phone])
}

model Vendor {
  id                 String     @id @default(cuid())
  name               String
  gstin              String?    @db.VarChar(15)
  vendorType         VendorType @default(REGISTERED)
  pan                String?    @db.VarChar(10)
  phone              String
  email              String?
  address            Json?
  bankDetails        Json?
  isMsme             Boolean    @default(false)
  msmeNumber         String?
  paymentTermsDays   Int        @default(0)
  outstandingBalance Decimal    @default(0) @db.Decimal(12, 2)
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  purchaseBills PurchaseBill[]
  expenses      Expense[]
}

model Invoice {
  id                    String        @id @default(cuid())
  invoiceNumber         String        @unique
  invoiceDate           DateTime
  invoiceType           InvoiceType
  supplyType            SupplyType

  customerId            String
  customer              Customer      @relation(fields: [customerId], references: [id])
  customerName          String
  customerGstin         String?
  billingAddress        Json?
  shippingAddress       Json?

  supplierStateCode     String        @default("09") @db.VarChar(2)
  placeOfSupplyCode     String        @default("09") @db.VarChar(2)
  isInterState          Boolean       @default(false)

  subtotal              Decimal       @db.Decimal(12, 2)
  totalCgst             Decimal       @db.Decimal(12, 2)
  totalSgst             Decimal       @db.Decimal(12, 2)
  totalIgst             Decimal       @default(0) @db.Decimal(12, 2)
  totalCess             Decimal       @default(0) @db.Decimal(12, 2)
  totalDiscount         Decimal       @default(0) @db.Decimal(12, 2)
  roundOff              Decimal       @default(0) @db.Decimal(8, 2)
  totalAmount           Decimal       @db.Decimal(12, 2)
  amountInWords         String

  originalInvoiceId     String?
  originalInvoice       Invoice?      @relation("CreditDebitNotes", fields: [originalInvoiceId], references: [id])
  creditDebitNotes      Invoice[]     @relation("CreditDebitNotes")
  originalInvoiceNumber String?

  status                InvoiceStatus @default(DRAFT)
  paymentStatus         PaymentStatus @default(UNPAID)
  paymentDueDate        DateTime?
  amountPaid            Decimal       @default(0) @db.Decimal(12, 2)
  amountDue             Decimal       @db.Decimal(12, 2)

  gstr1Period           String?
  gstr1Filed            Boolean       @default(false)

  // Link to app order (V2). NOT unique any more: a multi-seller marketplace order produces ONE
  // invoice per seller sub-order, so an Order can own several invoices (queried by orderId).
  orderId               String?
  // Marketplace (Phase 6): the per-seller SubOrder this invoice covers (one invoice / SubOrder).
  // Null for legacy single-invoice orders. @unique → idempotent regeneration keys off the sub-order.
  subOrderId            String?       @unique
  // The seller whose supply this invoice bills. Null ⇒ house (store-issued, the pre-Phase-6 path).
  sellerId              String?
  // ⚠️ GST/CA: for an EXTERNAL seller the tax invoice is issued under THE SELLER'S identity (their
  // GSTIN), not the store's — these snapshot the issuing supplier so the PDF/GSTR-1 reflect it.
  // All null ⇒ the PDF falls back to the store Company (house-seller / legacy path, unchanged).
  supplierName          String?
  supplierGstin         String?       @db.VarChar(15)
  supplierPan           String?       @db.VarChar(10)
  supplierAddress       String?
  supplierPhone         String?

  createdBy             String
  approvedBy            String?
  cancelledAt           DateTime?
  cancellationReason    String?
  pdfUrl                String?
  isLocked              Boolean       @default(false)

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  lineItems InvoiceLineItem[]

  @@index([invoiceDate])
  @@index([customerId])
  @@index([status])
  @@index([gstr1Period])
  @@index([amountDue])
  @@index([orderId])
  @@index([sellerId])
}

model InvoiceLineItem {
  id              String  @id @default(cuid())
  invoiceId       String
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineNumber      Int

  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  description     String
  hsnCode         String   @db.VarChar(8)

  quantity        Decimal  @db.Decimal(10, 3)
  unit            String
  unitPrice       Decimal  @db.Decimal(10, 2)

  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2)
  taxableValue    Decimal  @db.Decimal(12, 2)

  gstRate         Decimal  @db.Decimal(5, 2)
  cgstRate        Decimal  @db.Decimal(5, 2)
  cgstAmount      Decimal  @db.Decimal(10, 2)
  sgstRate        Decimal  @db.Decimal(5, 2)
  sgstAmount      Decimal  @db.Decimal(10, 2)
  igstRate        Decimal  @default(0) @db.Decimal(5, 2)
  igstAmount      Decimal  @default(0) @db.Decimal(10, 2)
  cessRate        Decimal  @default(0) @db.Decimal(5, 2)
  cessAmount      Decimal  @default(0) @db.Decimal(10, 2)

