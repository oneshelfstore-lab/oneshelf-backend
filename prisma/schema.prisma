generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (existing billing) ───────────────────────────────────────

enum CustomerType {
  B2B
  B2C
}

enum VendorType {
  REGISTERED
  UNREGISTERED
  COMPOSITION
}

enum InvoiceType {
  TAX_INVOICE
  BILL_OF_SUPPLY
  CREDIT_NOTE
  DEBIT_NOTE
}

enum SupplyType {
  B2B
  B2CS
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentType {
  RECEIPT
  PAYMENT
}

enum PaymentRelatedType {
  INVOICE
  PURCHASE_BILL
  EXPENSE
  SALARY
  TDS
  GST
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  NEFT
  RTGS
  CREDIT
}

enum PaymentTxnStatus {
  COMPLETED
  PENDING
  FAILED
  REVERSED
}

enum PurchaseBillStatus {
  DRAFT
  APPROVED
  PAID
  PARTIALLY_PAID
}

enum ExpenseCategory {
  RENT
  UTILITIES
  TRANSPORT
  OFFICE_SUPPLIES
  PACKAGING
  MAINTENANCE
  OTHER
}

enum SalaryStatus {
  DRAFT
  APPROVED
  PAID
}

enum TdsDeducteeType {
  VENDOR
  EMPLOYEE
  LANDLORD
}

enum TdsQuarter {
  Q1
  Q2
  Q3
  Q4
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  CANCEL
  EXPORT
  LOGIN
}

// ─── Enums (V2 — Oneshelf integration) ─────────────────────────────

enum UserRole {
  OWNER
  ACCOUNTANT
  BILLING_CLERK
  VIEWER
  CUSTOMER
  DELIVERY
  SELLER
}

enum ProductType {
  PACKAGED
  LOOSE
  PRODUCE
  DAIRY
}

enum PackageUnit {
  KG
  GRAM
  LITRE
  ML
  PIECE
  PACKET
  BOX
  DOZEN
  BUNDLE
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKED
  OUT_FOR_DELIVERY
  READY_FOR_PICKUP
  DELIVERED
  CANCELLED
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

enum OrderPaymentMethod {
  COD
  ONLINE
  UPI
  MONTHLY   // deferred-billing subscription order — settled via a monthly SubscriptionStatement
}

enum OrderPaymentStatus {
  PENDING
  PAID
  ADVANCE_PAID
  REFUND_INITIATED
  REFUNDED
}

enum CouponType {
  PERCENT
  FLAT
  FREE_DELIVERY
}

enum SubstitutionStatus {
  NONE
  PROPOSED
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  OPEN
  RESOLVED
}

enum QuoteStatus {
  PENDING
  QUOTED
  ACCEPTED
  DECLINED
  FULFILLED
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Enums (V3 — multi-seller marketplace) ─────────────────────────

enum SellerStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum SubOrderStatus {
  PLACED
  ACCEPTED
  PACKED
  COLLECTED
  CANCELLED
}

// ─── Enums (V4 — referral wallet / store credit) ───────────────────

enum WalletTxnType {
  REFERRAL_CREDIT   // referrer earns when their referee's first order is delivered
  ORDER_DEBIT       // store credit spent at checkout
  ORDER_REFUND      // credit returned when a wallet-paying order is cancelled
  ADJUSTMENT        // manual owner correction
}

enum ReferralStatus {
  PENDING    // code applied + welcome coupon minted; referrer not yet paid
  REWARDED   // referee's first order delivered → referrer credited
}

// ─── Subscriptions (milk / newspaper / recurring deliveries) ─────────
enum SubscriptionFrequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

// How the monthly statement settles.
enum SubscriptionBilling {
  COD
  WALLET
  AUTOPAY
}

enum SubscriptionStatementStatus {
  OPEN
  BILLED
  PAID
  PARTIALLY_PAID
  VOID
}

// ─── 0. User ────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  passwordHash     String?
  name             String
  role             UserRole  @default(CUSTOMER)
  isActive         Boolean   @default(true)
  mustChangePassword Boolean @default(false)
  lastLoginAt      DateTime?

  // Firebase-linked app users
  firebaseUid      String?   @unique
  phone            String?
  photoUrl         String?
  phoneVerified    Boolean   @default(false)

  // Delivery-agent availability — advisory toggle in the delivery dashboard. Shown to the owner
  // in the assignment picker (an "Offline" tag) but does NOT hard-block assignment. Defaults to
  // true so existing/pre-registered agents are assignable until they turn themselves off.
  isAvailableForDelivery Boolean @default(true)

  // Abandoned-cart push throttling
  lastCartReminderAt  DateTime?
  cartReminderCount   Int       @default(0)

  // Referral program (refer & earn)
  referralCode     String?   @unique
  referredById     String?
  referredBy       User?     @relation("UserReferrals", fields: [referredById], references: [id])
  referredUsers    User[]    @relation("UserReferrals")

  // Referral wallet / store credit (Phase 2). Denormalized spendable balance — the source of
  // truth for the guarded atomic decrement at checkout. Every mutation also writes a
  // WalletTransaction ledger row in the SAME db transaction (balance never drifts from the ledger).
  walletBalance    Decimal   @default(0) @db.Decimal(10, 2)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  addresses          Address[]
  cartItems          CartItem[]
  orders             Order[]          @relation("CustomerOrders")
  deliveryOrders     Order[]          @relation("DeliveryOrders")
  fcmTokens          FcmToken[]
  couponRedemptions  CouponRedemption[]
  favorites          Favorite[]
  orderRatings       OrderRating[]
  complaints         Complaint[]
  quoteRequests      QuoteRequest[]
  sellerAccount      Seller?          @relation("SellerOwner")
  walletTxns         WalletTransaction[]
  referralsMade      Referral[]       @relation("Referrer")
  referralReceived   Referral?        @relation("Referee")
  subscriptions          Subscription[]
  subscriptionStatements SubscriptionStatement[]

  @@index([phone])
}

// ─── 1. Company ──────────────────────────────────────────────────────

model Company {
  id                 String   @id @default(cuid())
  legalName          String
  tradeName          String
  pan                String   @db.VarChar(10)
  gstin              String   @db.VarChar(15)
  address            Json
  phone              String
  email              String
  logoUrl            String?
  financialYearStart Int      @default(4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── 2. Category ─────────────────────────────────────────────────────

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  imageUrl      String?
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  catalogProducts CatalogProduct[]
}

// ─── 3. CatalogProduct (Oneshelf app product — identity only) ────────

model CatalogProduct {
  id              String      @id @default(cuid())
  handle          String      @unique
  name            String
  nameHi          String?
  brand           String?
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id])
  subcategory     String?
  productType     ProductType
  description     String?
  hsnCode         String?     @db.VarChar(8)
  gstRate         Decimal?    @db.Decimal(5, 2)
  cessRate        Decimal     @default(0) @db.Decimal(5, 2)
  isPackaged      Boolean     @default(true)
  isTaxInclusive  Boolean     @default(true)
  isExempt        Boolean     @default(false)
  isBranded       Boolean     @default(false)
  // Owner opt-in: this product may be given as a free sample (Delight Phase 3B). Marking ≥1
  // product eligible is what turns the sample engine on.
  isSampleEligible Boolean    @default(false)
  // Owner opt-in: feature this product in the Home "99 Store" rail. Only surfaced when the product
  // is also actually priced ₹99 or less, so the "everything under ₹99" promise stays honest.
  featuredIn99Store Boolean   @default(false)
  // Owner opt-in: this product can be subscribed to (milk / newspaper / recurring). Gates the
  // "Subscribe" button on the PDP. Validated server-side on subscription create.
  isSubscribable   Boolean    @default(false)
  imageUrls       String[]    @default([])
  searchKeywords  String[]    @default([])
  isActive        Boolean     @default(true)
  // Marketplace: which seller owns this listing. Nullable + backfilled to the house seller, so
  // existing products keep working (a null seller is treated as the house seller everywhere).
  sellerId        String?
  seller          Seller?     @relation(fields: [sellerId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  variants        ProductVariant[]
  favorites       Favorite[]

  @@index([categoryId])
  @@index([name])
  @@index([isActive])
  @@index([sellerId])
}

// ─── Favorite (user's wishlist — product-level) ──────────────────────

model Favorite {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── OrderRating (post-delivery feedback, one per order) ─────────────

model OrderRating {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  stars     Int      // 1..5
  tags      String[] @default([]) // quick-tags e.g. "Fresh", "On time"
  comment   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Complaint (customer support ticket) ────────────────────────────

model Complaint {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId    String?         // optional link to a specific order
  subject    String
  message    String
  status     ComplaintStatus @default(OPEN)
  createdAt  DateTime        @default(now())
  resolvedAt DateTime?

  @@index([userId])
  @@index([status])
}

// ─── QuoteRequest (bulk / event price ask) ──────────────────────────

model QuoteRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String      // "Bulk" | "Monthly Ration" | "Event"
  note         String
  eventDate    String?     // free-text date the customer typed (kept verbatim)
  imageUrls    String[]    @default([]) // Firebase Storage public URLs (uploaded client-side)
  status       QuoteStatus @default(PENDING)
  quotedAmount Decimal?    @db.Decimal(10, 2)
  quoteMessage String?
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([status])
}

// ─── PartnerApplication ("Partner with us" — seller / delivery onboarding lead) ──
// Submitted UNAUTHENTICATED from the login page, so it deliberately does NOT link to a
// User row (the applicant may not have an account yet — phone is the only identity we
// have). The owner reviews these in their inbox and completes onboarding through the
// existing marketplace-seller / delivery-agent flows on approval.
model PartnerApplication {
  id           String                   @id @default(cuid())
  kind         String                   @default("SELLER") // "SELLER" | "DELIVERY"
  businessName String
  contactName  String
  phone        String
  email        String?
  gstin        String?
  category     String?
  message      String                   @default("")
  status       PartnerApplicationStatus @default(PENDING)
  reviewNote   String?
  createdAt    DateTime                 @default(now())
  reviewedAt   DateTime?

  @@index([status])
  @@index([phone])
}

// ─── 4. ProductVariant (the sellable SKU — owns size, price, stock) ──

model ProductVariant {
  id                String         @id @default(cuid())
  productId         String
  product           CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String         @unique
  barcode           String?
  packageSize       Decimal        @db.Decimal(10, 3)
  packageUnit       PackageUnit
  mrp               Decimal        @db.Decimal(10, 2)
  sellingPrice      Decimal        @db.Decimal(10, 2)
  costPrice         Decimal?       @db.Decimal(10, 2)
  stock             Decimal        @db.Decimal(12, 3)
  lowStockThreshold Int            @default(5)
  bulkMinQty        Int            @default(0)
  bulkPrice         Decimal?       @db.Decimal(10, 2)
  gstRateOverride   Decimal?       @db.Decimal(5, 2)
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  cartItems         CartItem[]
  orderItems        OrderItem[]
  substituteItems   OrderItem[]    @relation("SubstituteVariant")
  invoiceLines      InvoiceLineItem[]
  subscriptions     Subscription[]

  @@index([productId])
  @@index([barcode])
}

// ─── 5. Legacy Product (billing system — kept for existing invoices) ─

model Product {
  id              String   @id @default(cuid())
  name            String
  sku             String   @unique
  barcode         String?
  hsnCode         String   @db.VarChar(8)
  category        String
  gstRate         Decimal  @db.Decimal(5, 2)
  cessRate        Decimal  @default(0) @db.Decimal(5, 2)
  mrp             Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2)
  costPrice       Decimal  @db.Decimal(10, 2)
  isTaxInclusive  Boolean  @default(true)
  isExempt        Boolean  @default(false)
  isBranded       Boolean  @default(false)
  unit            String
  trackInventory  Boolean  @default(true)
  currentStock    Int      @default(0)
  minStockLevel   Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoiceLines InvoiceLineItem[]

  @@index([barcode])
  @@index([hsnCode])
  @@index([category])
}

// ─── 6. Banner ───────────────────────────────────────────────────────

model Banner {
  id              String    @id @default(cuid())
  imageUrl        String
  targetCategory  String?
  targetUrl       String?
  placement       String    @default("HOME")  // HOME | CATEGORY — which surface shows this banner
  displayOrder    Int       @default(0)
  isActive        Boolean   @default(true)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, displayOrder])
}

// ─── 6b. Brand ───────────────────────────────────────────────────────
// Owner-managed company/brand with an optional logo. CatalogProduct.brand stays the brand NAME
// (a string), so products reference a brand by name and the logo is looked up here — no product
// migration needed. Names are unique (upserted on create).
model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 7. Address ──────────────────────────────────────────────────────

model Address {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   @default("Home")
  addressLine   String
  landmark      String?
  city          String?
  state         String?
  pincode       String
  lat           Decimal? @db.Decimal(10, 7)
  lng           Decimal? @db.Decimal(10, 7)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  subscriptions Subscription[]

  @@index([userId])
}

// ─── 8. CartItem ─────────────────────────────────────────────────────

model CartItem {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity        Decimal        @db.Decimal(14, 6)
  savedForLater   Boolean        @default(false)
  isLoose         Boolean        @default(false)
  stepSize        Decimal?       @db.Decimal(10, 3)
  stepUnit        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, variantId, savedForLater])
  @@index([userId])
}

// ─── 9. Coupon ───────────────────────────────────────────────────────

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  couponType    CouponType
  value         Decimal    @db.Decimal(10, 2)
  minOrder      Decimal    @default(0) @db.Decimal(10, 2)
  maxDiscount   Decimal?   @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  validFrom     DateTime?
  validUntil    DateTime?
  usageLimit    Int?       // global cap across all users (null = unlimited)
  perUserLimit  Int?       // per-customer cap (null = unlimited)
  usageCount    Int        @default(0)
  description   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  redemptions   CouponRedemption[]

  @@index([code])
  @@index([isActive])
}

// One row per (coupon, user, order) redemption. Enables per-user limits and audit.
model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@index([userId])
}

// ─── Referral wallet (Phase 2 — store-credit ledger) ─────────────────
// Append-only ledger backing User.walletBalance. Every balance mutation writes one row in the SAME
// db transaction, snapshotting balanceAfter so history is self-verifying. @@unique([orderId, type])
// makes order-linked debits/refunds idempotent (≤1 per order per type); referral-credit rows have a
// null orderId and are unconstrained (Postgres treats NULLs as distinct in a unique index).
model WalletTransaction {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Decimal       @db.Decimal(10, 2)   // signed: +credit / −debit
  type         WalletTxnType
  balanceAfter Decimal       @db.Decimal(10, 2)
  orderId      String?       // set for ORDER_DEBIT / ORDER_REFUND
  referralId   String?       // set for REFERRAL_CREDIT
  statementId  String?       // set for a subscription monthly-statement ORDER_DEBIT
  note         String?
  createdAt    DateTime      @default(now())

  @@unique([orderId, type])
  @@index([userId, createdAt])
}

// One referral event per referee (refereeId @unique). Carries the reward state machine so the
// referrer is credited exactly once: PENDING→REWARDED via a guarded update + qualifyingOrderId @unique.
model Referral {
  id                String         @id @default(cuid())
  referrerId        String
  referrer          User           @relation("Referrer", fields: [referrerId], references: [id])
  refereeId         String         @unique
  referee           User           @relation("Referee", fields: [refereeId], references: [id])
  status            ReferralStatus @default(PENDING)
  welcomeCouponCode String?
  rewardAmount      Decimal?       @db.Decimal(10, 2)
  qualifyingOrderId String?        @unique
  rewardedAt        DateTime?
  createdAt         DateTime       @default(now())

  @@index([referrerId])
  @@index([status])
}

// ─── Scratch reward (Delight Phase 3A) ───────────────────────────────
// One scratch card per order. Outcome is rolled server-side at placement (idempotent, keyed by
// orderId) so re-opening the celebration screen can't re-roll. A win mints a single-use coupon
// through the existing Coupon system when the customer reveals it.

enum ScratchRewardType {
  NONE
  FREE_DELIVERY_NEXT
  FLAT_OFF
}

enum ScratchRewardStatus {
  UNSCRATCHED
  SCRATCHED
  EXPIRED
}

model ScratchReward {
  id         String              @id @default(cuid())
  orderId    String              @unique
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId     String
  type       ScratchRewardType   @default(NONE)
  value      Decimal?            @db.Decimal(10, 2) // flat-off ₹ amount when FLAT_OFF
  status     ScratchRewardStatus @default(UNSCRATCHED)
  couponCode String?             // minted on reveal for a win
  expiresAt  DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId])
}

// ─── Subscription (standing instruction → one Order per due date) ────
// The customer's recurring order. A daily engine turns each due subscription into a normal Order
// (paymentMethod=MONTHLY, deferred billing) that flows through the existing delivery pipeline. All
// dates use IST-midnight semantics. Pricing is FREE delivery (baked into the unit price) — see
// services/subscriptionEngine.ts.
model Subscription {
  id            String  @id @default(cuid())
  customerId    String
  customer      User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  // Snapshot for display continuity if the product later changes.
  productName   String
  imageUrl      String?
  quantity      Decimal  @db.Decimal(14, 6)
  isLoose       Boolean  @default(false)
  stepSize      Decimal? @db.Decimal(10, 3)
  stepUnit      String?

  frequency     SubscriptionFrequency
  intervalDays  Int?      // CUSTOM: every N days
  daysOfWeek    Int[]     @default([])  // WEEKLY: 0=Sun..6=Sat (IST weekday)
  dayOfMonth    Int?      // MONTHLY: 1..28 (capped — no month-end ambiguity)

  addressId     String?
  address       Address?  @relation(fields: [addressId], references: [id])
  billing       SubscriptionBilling @default(COD)

  status        SubscriptionStatus @default(ACTIVE)
  startDate     DateTime           // first delivery date (IST-midnight)
  endDate       DateTime?          // optional auto-stop
  pausedUntil   DateTime?          // auto-resume after this date
  nextDeliveryDate  DateTime?      // engine cursor (IST-midnight-in-UTC)
  lastGeneratedDate DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]  @relation("SubscriptionOrders")

  @@index([customerId])
  @@index([status, nextDeliveryDate])   // the engine's hot query
}

// ─── SubscriptionStatement (monthly consolidated khata bill) ─────────
// One bill per customer per month aggregating that month's DELIVERED subscription (MONTHLY) orders.
model SubscriptionStatement {
  id            String  @id @default(cuid())
  customerId    String
  customer      User    @relation(fields: [customerId], references: [id])
  periodYear    Int
  periodMonth   Int     // 1..12 (IST)
  totalAmount   Decimal @db.Decimal(12, 2) @default(0)
  deliveryCount Int     @default(0)
  status        SubscriptionStatementStatus @default(OPEN)
  billing       SubscriptionBilling
  invoiceId     String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]  @relation("StatementOrders")

  // One statement per customer per month PER TENDER — a customer who mixes COD + wallet subscriptions
  // gets one bill per tender (each settles differently). Same-tender customers get exactly one bill.
  @@unique([customerId, periodYear, periodMonth, billing])
  @@index([status])
}

// ─── 10. Order ───────────────────────────────────────────────────────

model Order {
  id                    String             @id @default(cuid())
  orderNumber           String             @unique
  customerId            String
  customer              User               @relation("CustomerOrders", fields: [customerId], references: [id])

  status                OrderStatus        @default(PLACED)
  fulfillmentType       FulfillmentType    @default(DELIVERY)
  paymentMethod         OrderPaymentMethod @default(COD)
  paymentStatus         OrderPaymentStatus @default(PENDING)

  // Snapshotted address
  addressId             String?
  address               Address?           @relation(fields: [addressId], references: [id])
  shippingName          String?
  shippingPhone         String?
  shippingAddress       String?
  shippingPincode       String?

  // Pricing
  subtotal              Decimal            @db.Decimal(12, 2)
  discount              Decimal            @default(0) @db.Decimal(10, 2)
  deliveryCharge        Decimal            @default(0) @db.Decimal(10, 2)
  taxableValue          Decimal            @default(0) @db.Decimal(12, 2)
  totalTax              Decimal            @default(0) @db.Decimal(10, 2)
  totalAmount           Decimal            @db.Decimal(12, 2)
  // Total the customer saved on this order vs MRP (Σ (mrp−price)×qty + coupon discount
  // + delivery waived). Snapshotted at placement so the celebration screen + year counter
  // are immutable and truthful. 0 for pre-migration orders.
  savedAmount           Decimal            @default(0) @db.Decimal(12, 2)
  couponCode            String?
  // Store credit applied as a payment tender (Phase 2): reduces the amount DUE after GST, does NOT
  // change taxableValue/totalTax. Refunded to the wallet if the order is cancelled.
  walletApplied         Decimal            @default(0) @db.Decimal(10, 2)

  // Delivery
  deliveryBoyId         String?
  deliveryBoy           User?              @relation("DeliveryOrders", fields: [deliveryBoyId], references: [id])
  deliveryOtpRequired   Boolean            @default(false)
  deliveredAt           DateTime?
  // Honest ETA: placedAt + StoreConfig.avg{Delivery,Pickup}Minutes. Rendered as a range/slot,
  // never a hard minutes-promise. Null = fall back to the store's next-day schedule label.
  estimatedReadyAt      DateTime?
  // Free sample (Delight Phase 3B). Rolled at placement; the customer sees the NAMED sample only
  // after the owner confirms it's physically in the bag (freeSamplePacked) — never before.
  freeSampleVariantId   String?
  freeSampleName        String?
  freeSampleImageUrl    String?
  freeSamplePacked      Boolean            @default(false)

  // Razorpay
  razorpayOrderId       String?
  razorpayPaymentId     String?

  // Invoice link
  invoiceId             String?            @unique

  notes                 String?
  // Client-supplied key to make order placement idempotent (dedupes double-tap/retry).
  idempotencyKey        String?            @unique
  // Customer-selected delivery window, e.g. "2026-06-08 09:00-12:00". Null = use the
  // store's default next-day schedule.
  deliverySlot          String?

  // Subscriptions — set when this order was auto-generated from a standing Subscription.
  // subscriptionDate is the IST-midnight date this delivery is FOR; the composite unique below is
  // the engine's idempotency guard (it can never generate two orders for the same sub on the same day).
  subscriptionId        String?
  subscription          Subscription?      @relation("SubscriptionOrders", fields: [subscriptionId], references: [id])
  subscriptionDate      DateTime?
  statementId           String?
  statement             SubscriptionStatement? @relation("StatementOrders", fields: [statementId], references: [id])

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  items                 OrderItem[]
  secret                OrderSecret?
  rating                OrderRating?
  scratchReward         ScratchReward?
  subOrders             SubOrder[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([deliveryBoyId])
  @@index([updatedAt])
  // Composite for the customer orders-list query (WHERE customerId ORDER BY createdAt DESC)
  // and owner status-filtered lists.
  @@index([customerId, createdAt])
  @@index([status, createdAt])
  // The engine can never create two orders for the same subscription on the same date.
  @@unique([subscriptionId, subscriptionDate])
  @@index([subscriptionId])
  @@index([statementId])
}

// ─── 11. OrderItem (snapshotted at sale time) ────────────────────────

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // Snapshotted product info
  productName     String
  variantSku      String
  imageUrl        String?
  hsnCode         String?        @db.VarChar(8)

  // Snapshotted pricing
  unitPrice       Decimal        @db.Decimal(10, 2)
  // MRP at sale time (per app-format unit/increment). Drives per-line savings + the invoice
  // strike-through. Nullable: pre-migration items have none.
  mrp             Decimal?       @db.Decimal(10, 2)
  quantity        Decimal        @db.Decimal(14, 6)
  gstRate         Decimal        @default(0) @db.Decimal(5, 2)
  taxableValue    Decimal        @default(0) @db.Decimal(12, 2)
  cgst            Decimal        @default(0) @db.Decimal(10, 2)
  sgst            Decimal        @default(0) @db.Decimal(10, 2)
  lineTotal       Decimal        @db.Decimal(12, 2)

  // Loose item metadata
  isLoose         Boolean        @default(false)
  stepSize        Decimal?       @db.Decimal(10, 3)
  stepUnit        String?
  packageUnit     String?

  // OOS substitution (owner proposes → customer approves/rejects at packing time)
  substitutionStatus    SubstitutionStatus @default(NONE)
  substituteVariantId   String?
  substituteVariant     ProductVariant?    @relation("SubstituteVariant", fields: [substituteVariantId], references: [id], onDelete: SetNull)
  substituteProductName String?
  substituteImageUrl    String?
  substituteUnitPrice   Decimal?           @db.Decimal(10, 2)
  substitutePriceDelta  Decimal?           @db.Decimal(10, 2) // positive = customer pays more

  // Marketplace: the seller fulfilling this line (snapshot at sale time) + the per-seller
  // sub-order it groups into. Null on pre-migration items (backfilled to the house seller).
  sellerId        String?
  subOrderId      String?
  subOrder        SubOrder?      @relation(fields: [subOrderId], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())

  @@index([orderId])
  @@index([sellerId])
}

// ─── 12. OrderSecret (delivery/pickup OTP) ───────────────────────────

model OrderSecret {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  otp           String   @db.VarChar(4)
  customerId    String
  fulfillmentType String
  attempts      Int      @default(0)
  maxAttempts   Int      @default(5)
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── 13. FcmToken ────────────────────────────────────────────────────

model FcmToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  deviceInfo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── 14. StoreConfig (singleton — app-facing store settings) ─────────

model StoreConfig {
  id                    String   @id @default(cuid())
  storeName             String   @default("Oneshelf")
  storeAddress          String?
  storePhone            String?
  storeEmail            String?
  gstin                 String?  @db.VarChar(15)
  pan                   String?  @db.VarChar(10)
  stateCode             String   @default("09") @db.VarChar(2)
  legalName             String?
  deliveryDateLabel     String   @default("Today")
  freeDeliveryAbove     Decimal  @default(500) @db.Decimal(10, 2)
  deliveryCharge        Decimal  @default(30) @db.Decimal(10, 2)
  isOrderingAllowed     Boolean  @default(true)
  operatingHoursStart   String?
  operatingHoursEnd     String?
  deliveryRadius        Decimal? @db.Decimal(5, 2)
  // Average fulfillment time used to compute the honest order ETA (shown as a range).
  avgDeliveryMinutes    Int      @default(40)
  avgPickupMinutes      Int      @default(20)
  // Delight engine (Phase 3). delightEnabled is the master kill switch. Scratch-card outcome
  // weights (a real NONE weight is mandatory so wins stay variable, not an entitlement);
  // scratchFlatOffValue = ₹ off for a FLAT_OFF win.
  delightEnabled            Boolean @default(true)
  scratchNoneWeight         Int     @default(55)
  scratchFreeDeliveryWeight Int     @default(30)
  scratchFlatOffWeight      Int     @default(15)
  scratchFlatOffValue       Int     @default(20)
  // Free-sample engine (Phase 3B). sampleChancePct = % of orders that get a sample (gated also by
  // having ≥1 eligible product + budget). sampleMaxValue caps the ₹ value of a giveaway item;
  // monthlySampleBudget caps total monthly sample spend (conservative count×maxValue cap).
  sampleChancePct           Int     @default(12)
  sampleMaxValue            Int     @default(50)
  monthlySampleBudget       Int     @default(500)
  // Referral wallet (Phase 2 — refer & earn). referralEnabled is the master gate.
  // referralRewardAmount = ₹ store credit the referrer earns when their referee's first order is
  // delivered; referralWelcomeAmount = ₹ off the referee's welcome coupon (min order
  // referralMinOrder, valid for referralWelcomeExpiryDays).
  referralEnabled           Boolean @default(true)
  referralRewardAmount      Int     @default(50)
  referralWelcomeAmount     Int     @default(50)
  referralMinOrder          Int     @default(199)
  referralWelcomeExpiryDays Int     @default(30)
  // Subscriptions (milk / newspaper / recurring). subscriptionsEnabled is the master kill switch;
  // subscriptionBillingDay is the day-of-month the prior month's statements are closed/billed;
  // defaultSubscriptionAgentId (optional) auto-assigns generated orders straight onto a delivery boy.
  subscriptionsEnabled       Boolean @default(true)
  subscriptionBillingDay     Int     @default(1)
  defaultSubscriptionAgentId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── 15. Marketplace (multi-seller) ──────────────────────────────────
// A Seller is an independent shop selling on the platform. The current single store is represented
// by ONE Seller with isHouse=true; every pre-existing product/order-item is backfilled to it, so
// the single-store path stays "a marketplace with exactly one seller" — zero behavior change.
// NOTE: distinct from the billing `Vendor` (a supplier you buy stock IN from). A Seller sells OUT.

model Seller {
  id                 String       @id @default(cuid())
  slug               String       @unique
  name               String
  logoUrl            String?
  // The SELLER-role User who logs in to manage this shop (null until onboarded/linked by phone).
  ownerUserId        String?      @unique
  ownerUser          User?        @relation("SellerOwner", fields: [ownerUserId], references: [id])
  // Shop / pickup location for the delivery collection run.
  shopAddress        String?
  city               String?
  pincode            String?
  lat                Decimal?     @db.Decimal(10, 7)
  lng                Decimal?     @db.Decimal(10, 7)
  phone              String?
  // KYC / GST (external shops with their own GSTIN).
  gstin              String?      @db.VarChar(15)
  pan                String?      @db.VarChar(10)
  bankDetails        Json?        // acct / IFSC / UPI for the manual payout
  // Commission the platform keeps on this seller's item subtotal (snapshotted onto each SubOrder).
  commissionPct      Decimal      @default(5) @db.Decimal(5, 2)
  // Running balance the platform owes this seller (manual-ledger settlement).
  outstandingBalance Decimal      @default(0) @db.Decimal(12, 2)
  status             SellerStatus @default(PENDING)
  isHouse            Boolean      @default(false)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  products  CatalogProduct[]
  subOrders SubOrder[]
  payouts   SellerPayout[]

  @@index([status])
}

// Per-(order, seller) split. One parent Order → N SubOrders (one per seller in the cart). A
// single-seller (house-only) order produces exactly one SubOrder, so the existing flow is unchanged.
model SubOrder {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId         String
  seller           Seller         @relation(fields: [sellerId], references: [id])
  status           SubOrderStatus @default(PLACED)
  // Money, snapshotted at placement.
  subtotal         Decimal        @db.Decimal(12, 2)  // seller's gross for this order
  commissionPct    Decimal        @db.Decimal(5, 2)   // snapshot of Seller.commissionPct
  commissionAmount Decimal        @db.Decimal(12, 2)  // = subtotal × pct (the platform's cut)
  tcsAmount        Decimal        @default(0) @db.Decimal(12, 2) // GST Sec-52 TCS (accrued for later)
  netPayable       Decimal        @db.Decimal(12, 2)  // = subtotal − commission − tcs (owed to seller)
  settled          Boolean        @default(false)
  payoutId         String?
  payout           SellerPayout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  // Fulfillment (collection run — Phase 5).
  packedAt         DateTime?
  collectedAt      DateTime?
  collectedById    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  items            OrderItem[]

  @@index([orderId])
  @@index([sellerId])
  @@index([sellerId, settled])
}

// Manual settlement record: the platform pays a seller their accumulated net and marks the
// covered sub-orders settled.
model SellerPayout {
  id          String     @id @default(cuid())
  sellerId    String
  seller      Seller     @relation(fields: [sellerId], references: [id])
  grossAmount Decimal    @db.Decimal(12, 2)
  commission  Decimal    @db.Decimal(12, 2)
  tcs         Decimal    @default(0) @db.Decimal(12, 2)
  netPaid     Decimal    @db.Decimal(12, 2)
  paidAt      DateTime   @default(now())
  mode        String?    // BANK_TRANSFER / UPI / CASH
  reference   String?
  note        String?
  createdAt   DateTime   @default(now())

  subOrders   SubOrder[]

  @@index([sellerId])
}

// ─── Existing billing models (unchanged) ─────────────────────────────

model Customer {
  id                  String       @id @default(cuid())
  name                String
  phone               String
  email               String?
  gstin               String?      @db.VarChar(15)
