generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (existing billing) ───────────────────────────────────────

enum CustomerType {
  B2B
  B2C
}

enum VendorType {
  REGISTERED
  UNREGISTERED
  COMPOSITION
}

enum InvoiceType {
  TAX_INVOICE
  BILL_OF_SUPPLY
  CREDIT_NOTE
  DEBIT_NOTE
}

enum SupplyType {
  B2B
  B2CS
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentType {
  RECEIPT
  PAYMENT
}

enum PaymentRelatedType {
  INVOICE
  PURCHASE_BILL
  EXPENSE
  SALARY
  TDS
  GST
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  NEFT
  RTGS
  CREDIT
}

enum PaymentTxnStatus {
  COMPLETED
  PENDING
  FAILED
  REVERSED
}

enum PurchaseBillStatus {
  DRAFT
  APPROVED
  PAID
  PARTIALLY_PAID
}

enum ExpenseCategory {
  RENT
  UTILITIES
  TRANSPORT
  OFFICE_SUPPLIES
  PACKAGING
  MAINTENANCE
  OTHER
}

enum SalaryStatus {
  DRAFT
  APPROVED
  PAID
}

enum TdsDeducteeType {
  VENDOR
  EMPLOYEE
  LANDLORD
}

enum TdsQuarter {
  Q1
  Q2
  Q3
  Q4
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  CANCEL
  EXPORT
  LOGIN
}

// ─── Enums (V2 — Oneshelf integration) ─────────────────────────────

enum UserRole {
  OWNER
  ACCOUNTANT
  BILLING_CLERK
  VIEWER
  CUSTOMER
  DELIVERY
}

enum ProductType {
  PACKAGED
  LOOSE
  PRODUCE
  DAIRY
}

enum PackageUnit {
  KG
  GRAM
  LITRE
  ML
  PIECE
  PACKET
  BOX
  DOZEN
  BUNDLE
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKED
  OUT_FOR_DELIVERY
  READY_FOR_PICKUP
  DELIVERED
  CANCELLED
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

enum OrderPaymentMethod {
  COD
  ONLINE
  UPI
}

enum OrderPaymentStatus {
  PENDING
  PAID
  ADVANCE_PAID
  REFUND_INITIATED
  REFUNDED
}

enum CouponType {
  PERCENT
  FLAT
  FREE_DELIVERY
}

enum SubstitutionStatus {
  NONE
  PROPOSED
  APPROVED
  REJECTED
}

// ─── 0. User ────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  passwordHash     String?
  name             String
  role             UserRole  @default(CUSTOMER)
  isActive         Boolean   @default(true)
  mustChangePassword Boolean @default(false)
  lastLoginAt      DateTime?

  // Firebase-linked app users
  firebaseUid      String?   @unique
  phone            String?
  photoUrl         String?
  phoneVerified    Boolean   @default(false)

  // Abandoned-cart push throttling
  lastCartReminderAt  DateTime?
  cartReminderCount   Int       @default(0)

  // Referral program (refer & earn)
  referralCode     String?   @unique
  referredById     String?
  referredBy       User?     @relation("UserReferrals", fields: [referredById], references: [id])
  referredUsers    User[]    @relation("UserReferrals")

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  addresses          Address[]
  cartItems          CartItem[]
  orders             Order[]          @relation("CustomerOrders")
  deliveryOrders     Order[]          @relation("DeliveryOrders")
  fcmTokens          FcmToken[]
  couponRedemptions  CouponRedemption[]
  favorites          Favorite[]
  orderRatings       OrderRating[]

  @@index([phone])
}

// ─── 1. Company ──────────────────────────────────────────────────────

model Company {
  id                 String   @id @default(cuid())
  legalName          String
  tradeName          String
  pan                String   @db.VarChar(10)
  gstin              String   @db.VarChar(15)
  address            Json
  phone              String
  email              String
  logoUrl            String?
  financialYearStart Int      @default(4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── 2. Category ─────────────────────────────────────────────────────

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  imageUrl      String?
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  catalogProducts CatalogProduct[]
}

// ─── 3. CatalogProduct (Oneshelf app product — identity only) ────────

model CatalogProduct {
  id              String      @id @default(cuid())
  handle          String      @unique
  name            String
  brand           String?
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id])
  subcategory     String?
  productType     ProductType
  description     String?
  hsnCode         String?     @db.VarChar(8)
  gstRate         Decimal?    @db.Decimal(5, 2)
  cessRate        Decimal     @default(0) @db.Decimal(5, 2)
  isPackaged      Boolean     @default(true)
  isTaxInclusive  Boolean     @default(true)
  isExempt        Boolean     @default(false)
  isBranded       Boolean     @default(false)
  imageUrls       String[]    @default([])
  searchKeywords  String[]    @default([])
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  variants        ProductVariant[]
  favorites       Favorite[]

  @@index([categoryId])
  @@index([name])
  @@index([isActive])
}

// ─── Favorite (user's wishlist — product-level) ──────────────────────

model Favorite {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── OrderRating (post-delivery feedback, one per order) ─────────────

model OrderRating {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  stars     Int      // 1..5
  tags      String[] @default([]) // quick-tags e.g. "Fresh", "On time"
  comment   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── 4. ProductVariant (the sellable SKU — owns size, price, stock) ──

model ProductVariant {
  id                String         @id @default(cuid())
  productId         String
  product           CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String         @unique
  barcode           String?
  packageSize       Decimal        @db.Decimal(10, 3)
  packageUnit       PackageUnit
  mrp               Decimal        @db.Decimal(10, 2)
  sellingPrice      Decimal        @db.Decimal(10, 2)
  costPrice         Decimal?       @db.Decimal(10, 2)
  stock             Decimal        @db.Decimal(12, 3)
  lowStockThreshold Int            @default(5)
  bulkMinQty        Int            @default(0)
  bulkPrice         Decimal?       @db.Decimal(10, 2)
  gstRateOverride   Decimal?       @db.Decimal(5, 2)
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  cartItems         CartItem[]
  orderItems        OrderItem[]
  substituteItems   OrderItem[]    @relation("SubstituteVariant")
  invoiceLines      InvoiceLineItem[]

  @@index([productId])
  @@index([barcode])
}

// ─── 5. Legacy Product (billing system — kept for existing invoices) ─

model Product {
  id              String   @id @default(cuid())
  name            String
  sku             String   @unique
  barcode         String?
  hsnCode         String   @db.VarChar(8)
  category        String
  gstRate         Decimal  @db.Decimal(5, 2)
  cessRate        Decimal  @default(0) @db.Decimal(5, 2)
  mrp             Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2)
  costPrice       Decimal  @db.Decimal(10, 2)
  isTaxInclusive  Boolean  @default(true)
  isExempt        Boolean  @default(false)
  isBranded       Boolean  @default(false)
  unit            String
  trackInventory  Boolean  @default(true)
  currentStock    Int      @default(0)
  minStockLevel   Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoiceLines InvoiceLineItem[]

  @@index([barcode])
  @@index([hsnCode])
  @@index([category])
}

// ─── 6. Banner ───────────────────────────────────────────────────────

model Banner {
  id              String    @id @default(cuid())
  imageUrl        String
  targetCategory  String?
  targetUrl       String?
  displayOrder    Int       @default(0)
  isActive        Boolean   @default(true)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, displayOrder])
}

// ─── 7. Address ──────────────────────────────────────────────────────

model Address {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   @default("Home")
  addressLine   String
  landmark      String?
  city          String?
  state         String?
  pincode       String
  lat           Decimal? @db.Decimal(10, 7)
  lng           Decimal? @db.Decimal(10, 7)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]

  @@index([userId])
}

// ─── 8. CartItem ─────────────────────────────────────────────────────

model CartItem {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity        Int
  savedForLater   Boolean        @default(false)
  isLoose         Boolean        @default(false)
  stepSize        Decimal?       @db.Decimal(10, 3)
  stepUnit        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, variantId, savedForLater])
  @@index([userId])
}

// ─── 9. Coupon ───────────────────────────────────────────────────────

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  couponType    CouponType
  value         Decimal    @db.Decimal(10, 2)
  minOrder      Decimal    @default(0) @db.Decimal(10, 2)
  maxDiscount   Decimal?   @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  validFrom     DateTime?
  validUntil    DateTime?
  usageLimit    Int?       // global cap across all users (null = unlimited)
  perUserLimit  Int?       // per-customer cap (null = unlimited)
  usageCount    Int        @default(0)
  description   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  redemptions   CouponRedemption[]

  @@index([code])
  @@index([isActive])
}

// One row per (coupon, user, order) redemption. Enables per-user limits and audit.
model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@index([userId])
}

// ─── 10. Order ───────────────────────────────────────────────────────

model Order {
  id                    String             @id @default(cuid())
  orderNumber           String             @unique
  customerId            String
  customer              User               @relation("CustomerOrders", fields: [customerId], references: [id])

  status                OrderStatus        @default(PLACED)
  fulfillmentType       FulfillmentType    @default(DELIVERY)
  paymentMethod         OrderPaymentMethod @default(COD)
  paymentStatus         OrderPaymentStatus @default(PENDING)

  // Snapshotted address
  addressId             String?
  address               Address?           @relation(fields: [addressId], references: [id])
  shippingName          String?
  shippingPhone         String?
  shippingAddress       String?
  shippingPincode       String?

  // Pricing
  subtotal              Decimal            @db.Decimal(12, 2)
  discount              Decimal            @default(0) @db.Decimal(10, 2)
  deliveryCharge        Decimal            @default(0) @db.Decimal(10, 2)
  taxableValue          Decimal            @default(0) @db.Decimal(12, 2)
  totalTax              Decimal            @default(0) @db.Decimal(10, 2)
  totalAmount           Decimal            @db.Decimal(12, 2)
  // Total the customer saved on this order vs MRP (Σ (mrp−price)×qty + coupon discount
  // + delivery waived). Snapshotted at placement so the celebration screen + year counter
  // are immutable and truthful. 0 for pre-migration orders.
  savedAmount           Decimal            @default(0) @db.Decimal(12, 2)
  couponCode            String?

  // Delivery
  deliveryBoyId         String?
  deliveryBoy           User?              @relation("DeliveryOrders", fields: [deliveryBoyId], references: [id])
  deliveryOtpRequired   Boolean            @default(false)
  deliveredAt           DateTime?
  // Honest ETA: placedAt + StoreConfig.avg{Delivery,Pickup}Minutes. Rendered as a range/slot,
  // never a hard minutes-promise. Null = fall back to the store's next-day schedule label.
  estimatedReadyAt      DateTime?

  // Razorpay
  razorpayOrderId       String?
  razorpayPaymentId     String?

  // Invoice link
  invoiceId             String?            @unique

  notes                 String?
  // Client-supplied key to make order placement idempotent (dedupes double-tap/retry).
  idempotencyKey        String?            @unique
  // Customer-selected delivery window, e.g. "2026-06-08 09:00-12:00". Null = use the
  // store's default next-day schedule.
  deliverySlot          String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  items                 OrderItem[]
  secret                OrderSecret?
  rating                OrderRating?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([deliveryBoyId])
  @@index([updatedAt])
  // Composite for the customer orders-list query (WHERE customerId ORDER BY createdAt DESC)
  // and owner status-filtered lists.
  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

// ─── 11. OrderItem (snapshotted at sale time) ────────────────────────

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // Snapshotted product info
  productName     String
  variantSku      String
  imageUrl        String?
  hsnCode         String?        @db.VarChar(8)

  // Snapshotted pricing
  unitPrice       Decimal        @db.Decimal(10, 2)
  // MRP at sale time (per app-format unit/increment). Drives per-line savings + the invoice
  // strike-through. Nullable: pre-migration items have none.
  mrp             Decimal?       @db.Decimal(10, 2)
  quantity        Int
  gstRate         Decimal        @default(0) @db.Decimal(5, 2)
  taxableValue    Decimal        @default(0) @db.Decimal(12, 2)
  cgst            Decimal        @default(0) @db.Decimal(10, 2)
  sgst            Decimal        @default(0) @db.Decimal(10, 2)
  lineTotal       Decimal        @db.Decimal(12, 2)

  // Loose item metadata
  isLoose         Boolean        @default(false)
  stepSize        Decimal?       @db.Decimal(10, 3)
  stepUnit        String?
  packageUnit     String?

  // OOS substitution (owner proposes → customer approves/rejects at packing time)
  substitutionStatus    SubstitutionStatus @default(NONE)
  substituteVariantId   String?
  substituteVariant     ProductVariant?    @relation("SubstituteVariant", fields: [substituteVariantId], references: [id], onDelete: SetNull)
  substituteProductName String?
  substituteImageUrl    String?
  substituteUnitPrice   Decimal?           @db.Decimal(10, 2)
  substitutePriceDelta  Decimal?           @db.Decimal(10, 2) // positive = customer pays more

  createdAt       DateTime       @default(now())

  @@index([orderId])
}

// ─── 12. OrderSecret (delivery/pickup OTP) ───────────────────────────

model OrderSecret {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  otp           String   @db.VarChar(4)
  customerId    String
  fulfillmentType String
  attempts      Int      @default(0)
  maxAttempts   Int      @default(5)
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── 13. FcmToken ────────────────────────────────────────────────────

model FcmToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  deviceInfo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── 14. StoreConfig (singleton — app-facing store settings) ─────────

model StoreConfig {
  id                    String   @id @default(cuid())
  storeName             String   @default("Oneshelf")
  storeAddress          String?
  storePhone            String?
  storeEmail            String?
  gstin                 String?  @db.VarChar(15)
  pan                   String?  @db.VarChar(10)
  stateCode             String   @default("09") @db.VarChar(2)
  legalName             String?
  deliveryDateLabel     String   @default("Today")
  freeDeliveryAbove     Decimal  @default(500) @db.Decimal(10, 2)
  deliveryCharge        Decimal  @default(30) @db.Decimal(10, 2)
  isOrderingAllowed     Boolean  @default(true)
  operatingHoursStart   String?
  operatingHoursEnd     String?
  deliveryRadius        Decimal? @db.Decimal(5, 2)
  // Average fulfillment time used to compute the honest order ETA (shown as a range).
  avgDeliveryMinutes    Int      @default(40)
  avgPickupMinutes      Int      @default(20)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── Existing billing models (unchanged) ─────────────────────────────

model Customer {
  id                  String       @id @default(cuid())
  name                String
  phone               String
  email               String?
  gstin               String?      @db.VarChar(15)
  customerType        CustomerType @default(B2C)
  panNumber           String?      @db.VarChar(10)
  billingAddress      Json?
  shippingAddress     Json?
  creditLimit         Decimal?     @db.Decimal(12, 2)
  paymentTermsDays    Int          @default(0)
  outstandingBalance  Decimal      @default(0) @db.Decimal(12, 2)
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  invoices Invoice[]

  @@index([gstin])
  @@index([phone])
}

model Vendor {
  id                 String     @id @default(cuid())
  name               String
  gstin              String?    @db.VarChar(15)
  vendorType         VendorType @default(REGISTERED)
  pan                String?    @db.VarChar(10)
  phone              String
  email              String?
  address            Json?
  bankDetails        Json?
  isMsme             Boolean    @default(false)
  msmeNumber         String?
  paymentTermsDays   Int        @default(0)
  outstandingBalance Decimal    @default(0) @db.Decimal(12, 2)
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  purchaseBills PurchaseBill[]
  expenses      Expense[]
}

model Invoice {
  id                    String        @id @default(cuid())
  invoiceNumber         String        @unique
  invoiceDate           DateTime
  invoiceType           InvoiceType
  supplyType            SupplyType

  customerId            String
  customer              Customer      @relation(fields: [customerId], references: [id])
  customerName          String
  customerGstin         String?
  billingAddress        Json?
  shippingAddress       Json?

  supplierStateCode     String        @default("09") @db.VarChar(2)
  placeOfSupplyCode     String        @default("09") @db.VarChar(2)
  isInterState          Boolean       @default(false)

  subtotal              Decimal       @db.Decimal(12, 2)
  totalCgst             Decimal       @db.Decimal(12, 2)
  totalSgst             Decimal       @db.Decimal(12, 2)
  totalIgst             Decimal       @default(0) @db.Decimal(12, 2)
  totalCess             Decimal       @default(0) @db.Decimal(12, 2)
  totalDiscount         Decimal       @default(0) @db.Decimal(12, 2)
  roundOff              Decimal       @default(0) @db.Decimal(8, 2)
  totalAmount           Decimal       @db.Decimal(12, 2)
  amountInWords         String

  originalInvoiceId     String?
  originalInvoice       Invoice?      @relation("CreditDebitNotes", fields: [originalInvoiceId], references: [id])
  creditDebitNotes      Invoice[]     @relation("CreditDebitNotes")
  originalInvoiceNumber String?

  status                InvoiceStatus @default(DRAFT)
  paymentStatus         PaymentStatus @default(UNPAID)
  paymentDueDate        DateTime?
  amountPaid            Decimal       @default(0) @db.Decimal(12, 2)
  amountDue             Decimal       @db.Decimal(12, 2)

  gstr1Period           String?
  gstr1Filed            Boolean       @default(false)

  // Link to app order (V2)
  orderId               String?       @unique

  createdBy             String
  approvedBy            String?
  cancelledAt           DateTime?
  cancellationReason    String?
  pdfUrl                String?
  isLocked              Boolean       @default(false)

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  lineItems InvoiceLineItem[]

  @@index([invoiceDate])
  @@index([customerId])
  @@index([status])
  @@index([gstr1Period])
  @@index([amountDue])
}

model InvoiceLineItem {
  id              String  @id @default(cuid())
  invoiceId       String
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineNumber      Int

  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  description     String
  hsnCode         String   @db.VarChar(8)

  quantity        Decimal  @db.Decimal(10, 3)
  unit            String
  unitPrice       Decimal  @db.Decimal(10, 2)

  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2)
  taxableValue    Decimal  @db.Decimal(12, 2)

  gstRate         Decimal  @db.Decimal(5, 2)
  cgstRate        Decimal  @db.Decimal(5, 2)
  cgstAmount      Decimal  @db.Decimal(10, 2)
  sgstRate        Decimal  @db.Decimal(5, 2)
  sgstAmount      Decimal  @db.Decimal(10, 2)
  igstRate        Decimal  @default(0) @db.Decimal(5, 2)
  igstAmount      Decimal  @default(0) @db.Decimal(10, 2)
  cessRate        Decimal  @default(0) @db.Decimal(5, 2)
  cessAmount      Decimal  @default(0) @db.Decimal(10, 2)

  totalAmount     Decimal  @db.Decimal(12, 2)
  isFreeItem      Boolean  @default(false)

  createdAt       DateTime @default(now())
}

model Payment {
  id              String             @id @default(cuid())
  paymentType     PaymentType
  relatedType     PaymentRelatedType
  relatedId       String
  amount          Decimal            @db.Decimal(12, 2)
  paymentMode     PaymentMode
  paymentDate     DateTime
  referenceNumber String?
  bankAccount     String?
  narration       String?
  status          PaymentTxnStatus   @default(COMPLETED)
  isReconciled    Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([relatedType, relatedId])
  @@index([paymentDate])
}

model PurchaseBill {
  id               String             @id @default(cuid())
  vendorId         String
  vendor           Vendor             @relation(fields: [vendorId], references: [id])
  billNumber       String
  billDate         DateTime
  receivedDate     DateTime
  vendorGstin      String?            @db.VarChar(15)

  subtotal         Decimal            @db.Decimal(12, 2)
  totalCgst        Decimal            @db.Decimal(12, 2)
  totalSgst        Decimal            @db.Decimal(12, 2)
  totalIgst        Decimal            @default(0) @db.Decimal(12, 2)
  totalCess        Decimal            @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal            @db.Decimal(12, 2)
  tdsAmount        Decimal            @default(0) @db.Decimal(10, 2)
  netPayable       Decimal            @db.Decimal(12, 2)

  itcEligible      Boolean            @default(true)
  itcClaimedInPeriod String?
  isReverseCharge  Boolean            @default(false)

  status           PurchaseBillStatus @default(DRAFT)
  paymentDueDate   DateTime?
  documentUrl      String?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  lineItems PurchaseBillLine[]

  @@index([vendorId])
  @@index([billDate])
}

model PurchaseBillLine {
  id              String       @id @default(cuid())
  purchaseBillId  String
  purchaseBill    PurchaseBill @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)

  description     String
  hsnCode         String       @db.VarChar(8)
  quantity        Decimal      @db.Decimal(10, 3)
  unitPrice       Decimal      @db.Decimal(10, 2)
  taxableValue    Decimal      @db.Decimal(12, 2)
  gstRate         Decimal      @db.Decimal(5, 2)
  cgstAmount      Decimal      @db.Decimal(10, 2)
  sgstAmount      Decimal      @db.Decimal(10, 2)
  igstAmount      Decimal      @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal      @db.Decimal(12, 2)

  createdAt       DateTime     @default(now())
}

model Expense {
  id              String          @id @default(cuid())
  expenseDate     DateTime
  category        ExpenseCategory
  description     String
  amount          Decimal         @db.Decimal(12, 2)
  gstApplicable   Boolean         @default(false)
  gstAmount       Decimal?        @db.Decimal(10, 2)
  vendorId        String?
  vendor          Vendor?         @relation(fields: [vendorId], references: [id])
  tdsApplicable   Boolean         @default(false)
  tdsSection      String?
  tdsAmount       Decimal         @default(0) @db.Decimal(10, 2)
  paymentMode     PaymentMode
  referenceNumber String?
  documentUrl     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Employee {
  id            String   @id @default(cuid())
  name          String
  employeeCode  String   @unique
  designation   String
  department    String
  joiningDate   DateTime
  phone         String
  email         String?
  pan           String?  @db.VarChar(10)
  aadhaar       String?  @db.VarChar(12)
  bankDetails   Json?
  monthlySalary Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salaryRecords SalaryRecord[]
}

model SalaryRecord {
  id               String       @id @default(cuid())
  employeeId       String
  employee         Employee     @relation(fields: [employeeId], references: [id])
  month            Int
  year             Int
  basicSalary      Decimal      @db.Decimal(10, 2)
  hra              Decimal      @default(0) @db.Decimal(10, 2)
  otherAllowances  Decimal      @default(0) @db.Decimal(10, 2)
  grossSalary      Decimal      @db.Decimal(10, 2)
  pfDeduction      Decimal      @default(0) @db.Decimal(10, 2)
  esiDeduction     Decimal      @default(0) @db.Decimal(10, 2)
  tdsDeduction     Decimal      @default(0) @db.Decimal(10, 2)
  otherDeductions  Decimal      @default(0) @db.Decimal(10, 2)
  netSalary        Decimal      @db.Decimal(10, 2)
  paymentDate      DateTime?
  paymentMode      PaymentMode?
  paymentRef       String?
  status           SalaryStatus @default(DRAFT)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([employeeId, month, year])
}

model TdsRecord {
  id               String         @id @default(cuid())
  deducteeType     TdsDeducteeType
  deducteeId       String
  deducteeName     String
  deducteePan      String?        @db.VarChar(10)
  section          String
  paymentDate      DateTime
  paymentAmount    Decimal        @db.Decimal(12, 2)
  tdsRate          Decimal        @db.Decimal(5, 2)
  tdsAmount        Decimal        @db.Decimal(10, 2)
  challanNumber    String?
  challanDate      DateTime?
  depositedToGovt  Boolean        @default(false)
  depositDate      DateTime?
  quarter          TdsQuarter
  financialYear    String
  returnFiled      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model InvoiceCounter {
  id             String   @id @default(cuid())
  prefix         String
  financialYear  String
  lastNumber     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([prefix, financialYear])
}

model AuditLog {
  id         String      @id @default(cuid())
  timestamp  DateTime    @default(now())
  userId     String
  action     AuditAction
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([timestamp])
}

model HsnMaster {
  id             String   @id @default(cuid())
  code           String
  description    String
  defaultGstRate Decimal  @db.Decimal(5, 2)
  cessRate       Decimal  @default(0) @db.Decimal(5, 2)
  isExempt       Boolean  @default(false)
  category       String
  createdAt      DateTime @default(now())

  @@unique([code, description])
  @@index([code])
}
